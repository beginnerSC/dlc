{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Launch (Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/tests/cpp/Debug/dlc_core_test.exe",
            // "args": [],
            "stopAtEntry": false,
            // "preLaunchTask": "CMake: config and build",
            "preLaunchTask": "CMake: build (Debug)",
            "cwd": "${workspaceFolder}",
            // "environment": [],
        },
        {
            "name": "Pytest (Matching Test File)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/python/test_${fileBasenameNoExtension}.py",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}